# SkyWalking 配置示例
# 文件名：agent.config
# 用途：SkyWalking Java Agent 配置

# ==================== SkyWalking Agent 配置 ====================

# Agent 服务名称（重要：用于在 UI 中识别服务）
agent.service_name=${SW_AGENT_NAME:interview-observability}

# 后端服务地址（OAP Server）
collector.backend_service=${SW_COLLECTOR_BACKEND_SERVICE:127.0.0.1:11800}

# Agent 采样率（1.0 = 100%，0.5 = 50%）
agent.sample_n_per_3_secs=${SW_AGENT_SAMPLE:-1}

# 是否开启日志输出
agent.logging.level=${SW_LOGGING_LEVEL:DEBUG}
agent.logging.dir=${SW_LOGGING_DIR:/tmp/skywalking-logs}

# ==================== 插件配置 ====================

# Spring MVC 插件配置
plugin.springmvc.use_original_controller_name=${SW_PLUGIN_SPRINGMVC_USE_ORIGINAL_CONTROLLER_NAME:false}

# HTTP 客户端插件配置
plugin.httpclient.trust_hosts=${SW_PLUGIN_HTTPCLIENT_TRUST_HOSTS:*}

# 数据库连接池插件
plugin.datasource.plugins=${SW_PLUGIN_DATASOURCE:hikari,druid,dbcp}

# ==================== 追踪配置 ====================

# 是否开启链路追踪
agent.trace.ignore_suffix=${SW_AGENT_TRACE_IGNORE_SUFFIX:.css,.js,.html,.png,.jpg,.jpeg,.gif,.ico}

# 慢调用阈值（毫秒）
agent.slow_query_threshold=${SW_AGENT_SLOW_QUERY_THRESHOLD:1000}

# 最大 Span 数量限制
agent.span_limit_per_segment=${SW_AGENT_SPAN_LIMIT_PER_SEGMENT:300}

# ==================== 度量配置 ====================

# 是否开启 JVM 指标采集
agent.collector.jvm_metrics.enable=${SW_AGENT_COLLECTOR_JVM_METRICS_ENABLE:true}

# JVM 指标采集间隔（秒）
agent.collector.jvm_metrics.interval=${SW_AGENT_COLLECTOR_JVM_METRICS_INTERVAL:20}

# ==================== 告警配置 ====================

# 是否开启客户端告警
agent.alert.enable=${SW_AGENT_ALERT_ENABLE:true}

# ==================== 使用示例 ====================
# 
# 启动应用时添加 Java Agent：
# java -javaagent:/path/to/skywalking-agent.jar \
#      -Dskywalking.agent.service_name=interview-observability \
#      -Dskywalking.collector.backend_service=127.0.0.1:11800 \
#      -jar interview-observability.jar
#
# Docker 环境变量方式：
# docker run -e SW_AGENT_NAME=interview-observability \
#            -e SW_COLLECTOR_BACKEND_SERVICE=oap:11800 \
#            your-image
